PORT=3000
NODE_ENV=development

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=inkmind

JWT_SECRET=change-me-to-a-long-random-string

# 微信小程序（登录用）
WECHAT_APPID=
WECHAT_APPSECRET=

# 开发时可开启：任意 code 映射到固定测试用户，不请求微信
WECHAT_DEV_MOCK=0

# 免费版收藏上限
FREE_ENTRY_LIMIT=100

# 开发：启动 API 前自动执行 backend/schema.sql（仅 NODE_ENV=development）
# AUTO_INIT_DB=1

# 若 schema 不在默认位置，可指定绝对路径
# SCHEMA_PATH=/absolute/path/to/schema.sql
