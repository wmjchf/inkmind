PORT=3000
NODE_ENV=development

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=inkmind

JWT_SECRET=change-me-to-a-long-random-string

# 微信小程序（登录用）
WECHAT_APPID=
WECHAT_APPSECRET=

# 开发时可开启：任意 code 映射到固定测试用户，不请求微信
WECHAT_DEV_MOCK=0

# 免费版收藏上限
FREE_ENTRY_LIMIT=100

# 阿里云文字识别（OpenAPI 自签名，无需 Node SDK；接口为全文识别高精版 RecognizeAdvanced）
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# 可选，默认华东1公网：ocr-api.cn-hangzhou.aliyuncs.com
# ALIYUN_OCR_ENDPOINT=ocr-api.cn-hangzhou.aliyuncs.com

# AI：打标签 + 解读共用同一模型（OpenAI 兼容 Chat Completions）
# 推荐：阿里云百炼 DashScope + Qwen3.6-Plus
# DASHSCOPE_API_KEY=
# 国内默认：https://dashscope.aliyuncs.com/compatible-mode/v1
# 国际站示例：https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AI_MODEL=qwen3.6-plus
# 兼容旧配置名（未设 AI_MODEL 时生效）：AI_TAG_MODEL=
#
# 或使用 OpenAI 官方 / 其它兼容网关（未配置 DASHSCOPE_API_KEY 时生效）
# OPENAI_API_KEY=
# AI_CHAT_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini
# AI_PROVIDER=

# 开发：启动 API 前自动执行 backend/schema.sql（仅 NODE_ENV=development）
# AUTO_INIT_DB=1

# 若 schema 不在默认位置，可指定绝对路径
# SCHEMA_PATH=/absolute/path/to/schema.sql
